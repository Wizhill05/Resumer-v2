<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page {
      size: A4;
      margin: {{ page_margin_mm }}mm;
    }
    body {
      font-family: Arial, sans-serif;
      font-size: {{ font_size }}pt;
      line-height: 1.3;
      color: #222222;
      margin: 0;
      padding: 0;
    }
    .header {
      border-bottom: 2px solid #333333;
      padding-bottom: 5px;
      margin-bottom: 10px;
    }
    h1 {
      font-size: 1.6em;
      margin: 0 0 3px 0;
      color: #000000;
      font-weight: bold;
      letter-spacing: -0.5px;
    }
    .contact-info {
      font-size: 0.85em;
      color: #444444;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .section-title {
      font-size: 1.05em;
      font-weight: bold;
      color: #000000;
      background-color: #f2f2f2;
      padding: 2px 5px;
      margin-top: 10px;
      margin-bottom: 5px;
      text-transform: uppercase;
    }
    .summary {
      margin-bottom: 8px;
      font-size: 0.95em;
      text-align: justify;
    }
    .skills-table {
      width: 100%;
      margin-bottom: 8px;
      border-collapse: collapse;
    }
    .skills-table td {
      padding: 1px 0;
      vertical-align: top;
    }
    .item {
      margin-bottom: 6px;
    }
    .item-header {
      font-weight: bold;
      display: flex;
      justify-content: space-between;
      color: #000000;
    }
    .item-subheader {
      font-style: italic;
      display: flex;
      justify-content: space-between;
      color: #333333;
    }
    ul {
      margin: 0;
      padding-left: 15px;
    }
    li {
      margin-bottom: 2px;
    }
  </style>
</head>
<body>

  <div class="header">
    <table style="width: 100%;">
      <tr>
        <td><h1>{{ profile.full_name }}</h1></td>
        <td style="text-align: right; font-size: 0.85em; color: #444444; line-height: 1.3;">
          {% if profile.email %}{{ profile.email }}<br>{% endif %}
          {% if profile.phone %}{{ profile.phone }}<br>{% endif %}
          {% if profile.location %}{{ profile.location }}{% endif %}
        </td>
      </tr>
    </table>
    {% if profile.linkedin_url or profile.github_url or profile.portfolio_url %}
    <div style="font-size: 0.8em; color: #555555; margin-top: 2px; border-top: 1px solid #eeeeee; padding-top: 2px;">
      {% if profile.linkedin_url %}<span>LinkedIn: {{ profile.linkedin_url }}</span> &nbsp;|&nbsp; {% endif %}
      {% if profile.github_url %}<span>GitHub: {{ profile.github_url }}</span> &nbsp;|&nbsp; {% endif %}
      {% if profile.portfolio_url %}<span>Portfolio: {{ profile.portfolio_url }}</span>{% endif %}
    </div>
    {% endif %}
  </div>

  {% if resume.summary %}
  <div class="section-title">Summary</div>
  <div class="summary">
    {{ resume.summary }}
  </div>
  {% endif %}

  {% if resume.skills %}
  <div class="section-title">Skills</div>
  <table class="skills-table">
    {% for category, items in resume.skills.items() %}
    <tr>
      <td style="width: 20%; font-weight: bold; color: #333333;">{{ category }}:</td>
      <td style="width: 80%;">{{ items | join(', ') }}</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}

  {% if resume.experiences %}
  <div class="section-title">Experience</div>
  {% for exp in resume.experiences %}
  <div class="item">
    <div class="item-header">
      <span>{{ exp.role }}</span>
      <span>{{ exp.start_date }} &ndash; {{ exp.end_date or 'Present' }}</span>
    </div>
    <div class="item-subheader">
      <span>{{ exp.organization }}</span>
      <span>{{ exp.location }}</span>
    </div>
    <ul>
      {% for bullet in exp.bullet_points %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
  {% endif %}

  {% if resume.projects %}
  <div class="section-title">Projects</div>
  {% for proj in resume.projects %}
  <div class="item">
    <div class="item-header">
      <span>{{ proj.name }}</span>
      {% if proj.start_date %}
      <span>{{ proj.start_date }} &ndash; {{ proj.end_date or 'Present' }}</span>
      {% endif %}
    </div>
    {% if proj.technologies %}
    <div class="item-subheader">
      <span>{{ proj.technologies | join(', ') }}</span>
    </div>
    {% endif %}
    <ul>
      {% for bullet in proj.bullet_points %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
  {% endif %}

  {% if resume.education %}
  <div class="section-title">Education</div>
  {% for edu in resume.education %}
  <div class="item">
    <div class="item-header">
      <span>{{ edu.institution }}</span>
      <span>{{ edu.start_date }} &ndash; {{ edu.end_date }}</span>
    </div>
    <div class="item-subheader">
      <span>{{ edu.degree }}</span>
      {% if edu.gpa %}<span>GPA: {{ edu.gpa }}</span>{% endif %}
    </div>
  </div>
  {% endfor %}
  {% endif %}

</body>
</html>
