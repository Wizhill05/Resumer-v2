<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    {% include 'personal-classic/style.css' %}
    body { font-size: {{ font_size }}pt; }
    @page {
      margin: {{ page_margin_mm }}mm;
      margin-bottom: {{ page_margin_mm * 0.7 }}mm;
    }
  </style>
</head>
<body>

<!-- Header -->
<div class="header-row">
  <div class="header-left">
    <h1>{{ profile.full_name or '' }}</h1>
    {% if profile.subtitle %}
    <div class="subtitle">{{ profile.subtitle }}</div>
    {% endif %}
  </div>
  <div class="header-right">
    <div>
      {% if profile.email %}✉ <a href="mailto:{{ profile.email }}">{{ profile.email }}</a>{% endif %}
      {% if profile.linkedin_url %} | &#x1F517; <a href="{{ profile.linkedin_url }}">{{ profile.linkedin_url | replace('https://', '') | replace('http://', '') }}</a>{% endif %}
    </div>
    <div>
      {% if profile.phone %}✆ {{ profile.phone }}{% endif %}
      {% if profile.github_url %} | &#xe60f; <a href="{{ profile.github_url }}">{{ profile.github_url | replace('https://', '') | replace('http://', '') }}</a>{% endif %}
    </div>
  </div>
</div>

<!-- Summary -->
{% if resume.summary %}
<h2>PROFESSIONAL SUMMARY</h2>
<p class="body-indent">{{ resume.summary | markdown }}</p>
{% endif %}

<!-- Education -->
{% if resume.education %}
<h2>EDUCATION</h2>
{% for edu in resume.education %}
<dl>
  <dt><strong>{{ edu.degree }}</strong> | {{ edu.institution }}{% if edu.location %}, {{ edu.location }}{% endif %}</dt>
  <dd>
    {% if edu.start_date and edu.end_date %}{{ edu.start_date | format_date }} – {{ edu.end_date | format_date }}
    {% elif edu.end_date %}{{ edu.end_date | format_date }}
    {% elif edu.start_date %}{{ edu.start_date | format_date }}{% endif %}
    {% if edu.gpa %} | GPA: {{ edu.gpa }}{% endif %}
  </dd>
</dl>
{% endfor %}
{% endif %}

<!-- Skills -->
{% if resume.skills %}
<h2>SKILLS</h2>
<table class="skills-table">
{% for category, items in resume.skills.items() %}
  <tr>
    <td>{{ category }}</td>
    <td>{{ items | join(', ') }}</td>
  </tr>
{% endfor %}
</table>
{% endif %}

<!-- Projects -->
{% if resume.projects %}
<h2>PROJECTS</h2>
{% for project in resume.projects %}
{% set project_link = (project.github_url or project.live_url or '') | trim %}
{% set project_summary = (project.project_summary or '') | trim %}
{% set link_label = project_link | replace('https://', '') | replace('http://', '') | replace('www.', '') | replace('github.com/', '') %}
<dl>
  <dt>
    <strong>{{ project.name }}
    {%- if project_summary %} | {{ project_summary | markdown }}{% endif %}
    {%- if project_link %} | <a href="{{ project_link if project_link.startswith('http') else 'https://' + project_link }}">{{ link_label }}</a>{% endif %}
    </strong>
  </dt>
  <dd></dd>
</dl>
<ul>
{% for bullet in project.bullet_points %}
  <li>{{ bullet | markdown }}</li>
{% endfor %}
</ul>
{% endfor %}
{% endif %}

<!-- Experience -->
{% if resume.experiences %}
<h2>EXPERIENCE</h2>
{% for exp in resume.experiences %}
<dl>
  <dt><strong>{{ exp.role }} | {{ exp.organization }}{% if exp.location %} | {{ exp.location }}{% endif %}</strong></dt>
  <dd>
    {% if exp.start_date %}{{ exp.start_date | format_date }}{% endif %}
    {% if exp.start_date and exp.end_date %} – {% endif %}
    {% if exp.end_date %}{{ exp.end_date | format_date }}{% else %}Present{% endif %}
  </dd>
</dl>
<ul>
{% for bullet in exp.bullet_points %}
  <li>{{ bullet | markdown }}</li>
{% endfor %}
</ul>
{% endfor %}
{% endif %}

<!-- Extra-Curricular Activities & Achievements -->
{% if resume.extracurriculars %}
<h2>EXTRA-CURRICULAR ACTIVITIES & ACHIEVEMENTS</h2>
<div class="extracurriculars-section">
  <ul>
  {% for ex in resume.extracurriculars %}
    <li>
      {{ ex.title }}{% if ex.organization %} | {{ ex.organization }}{% endif %}
      {%- if ex.start_date or ex.end_date %} ({% endif -%}
      {%- if ex.start_date %}{{ ex.start_date | format_date }}{% endif -%}
      {%- if ex.start_date and ex.end_date %} – {% endif -%}
      {%- if ex.end_date %}{{ ex.end_date | format_date }}{% elif ex.start_date %}Present{% endif -%}
      {%- if ex.start_date or ex.end_date %}){% endif -%}
      
      {% if ex.bullet_points %}
      <ul>
      {% for bullet in ex.bullet_points %}
        <li>{{ bullet | markdown }}</li>
      {% endfor %}
      </ul>
      {% endif %}
    </li>
  {% endfor %}
  </ul>
</div>
{% endif %}

</body>
</html>
